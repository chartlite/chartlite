{
  "name": "@chartlite/svelte",
  "version": "1.0.0",
  "description": "Svelte wrapper for Chartlite — beautiful, lightweight charts",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "charts",
    "svelte",
    "visualization",
    "chartlite"
  ],
  "author": "Riel St. Amand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chartlite/chartlite.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/chartlite/chartlite/issues"
  },
  "homepage": "https://github.com/chartlite/chartlite#readme",
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "@chartlite/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
